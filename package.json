{
  "name": "pi-better-skills",
  "version": "1.2.1",
  "description": "`pi-better-skills` makes Pi skills resolve their bundled files from the skill directory, not from whatever project you are working in.",
  "main": "index.js",
  "directories": {
    "test": "tests"
  },
  "scripts": {
    "test": "bun test",
    "build": "bun build index.ts --target=node --external @earendil-works/pi-coding-agent --external @earendil-works/pi-tui --outdir=."
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/edxeth/pi-better-skills.git"
  },
  "keywords": [
    "pi-package"
  ],
  "pi": {
    "extensions": [
      "./index.ts"
    ]
  },
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/edxeth/pi-better-skills/issues"
  },
  "homepage": "https://github.com/edxeth/pi-better-skills#readme",
  "dependencies": {
    "picomatch": "^4.0.4"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*"
  }
}
